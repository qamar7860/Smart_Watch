#include <Arduino.h>
#include <lvgl.h>
#include "lv_conf.h"
#include <TFT_eSPI.h> //  display library 
#include "CST816S.h"   // touch library

// Screen Resolution
static const uint16_t screenWidth  = 240;
static const uint16_t screenHeight = 240;

// LVGL v9 static draw buffer (1/10th of screen size)
static uint8_t buf[screenWidth * screenHeight / 10 * (LV_COLOR_DEPTH / 8)];

TFT_eSPI tft = TFT_eSPI(screenWidth, screenHeight);
CST816S touch(6, 7, 13, 5); // sda, scl, rst, irq

//Display Flush Callback
void my_disp_flush(lv_display_t * disp, const lv_area_t * area, uint8_t * px_map) {
    uint32_t w = (area->x2 - area->x1 + 1);
    uint32_t h = (area->y2 - area->y1 + 1);

    // Start TFT window transmission
    tft.startWrite();
    tft.setAddrWindow(area->x1, area->y1, w, h);
    
    // Push the pixel data cast to 16-bit colors (RGB565)
    tft.pushColors((uint16_t *)px_map, w * h, true);
    tft.endWrite();

    lv_display_flush_ready(disp);
}

void setup() {
    Serial.begin(115200);
    
    // Set up the backlight control pin safely
    pinMode(TFT_BL, OUTPUT);
    digitalWrite(TFT_BL, HIGH);
    
    tft.begin();
    tft.setRotation(0);
    touch.begin();
    tft.fillScreen(TFT_BLUE); // Diagnostic color check

    // 1. Initialize LVGL Core
    lv_init();

    // 2. Create the display device object
    lv_display_t * disp = lv_display_create(screenWidth, screenHeight);

    // 3. Assign the buffer and configuration mode to the display object
    lv_display_set_buffers(disp, buf, NULL, sizeof(buf), LV_DISPLAY_RENDER_MODE_PARTIAL);

    // 4. Set the flush callback function
    lv_display_set_flush_cb(disp, my_disp_flush);

  
    // Create a simple button in the center
    lv_obj_t *btn = lv_button_create(lv_screen_active()); 
    lv_obj_align(btn, LV_ALIGN_CENTER, 0, 0);

    // Put a text label inside the button
    lv_obj_t *label = lv_label_create(btn);
    lv_label_set_text(label, "  Hello QAMAR");
}

void loop() {
    lv_timer_handler(); // Let LVGL do its magic
    delay(5);
}
